# Archivos y directorios específicos de sistemas operativos
# ---
.DS_Store  # Archivo de metadatos de macOS
Thumbs.db  # Archivo de caché de miniaturas de Windows
ehthumbs.db
Desktop.ini
.vscode/  # Directorio de configuración de Visual Studio Code (opcional, si no se quiere compartir)
# Se sugiere ignorar configuraciones de IDEs para evitar conflictos entre desarrolladores.

---
# Entornos de Python
# ---
# Entornos virtuales
venv/
env/
.venv/
.python-version  # Para pyenv
pip-log.txt
# Es crucial no subir entornos virtuales ya que cada uno tiene su propia configuración
# y las dependencias deben ser manejadas por el contenedor Docker.

---
# Archivos de caché y compilación
# ---
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
*.egg-info/
build/
dist/
# Estos archivos se generan automáticamente y no deben ser versionados.

---
# Archivos de Docker
# ---
# Contenedores Docker
# Es importante no versionar las imágenes, volúmenes o bases de datos
# generadas por Docker. El Dockerfile y docker-compose.yml son los
# únicos archivos de Docker que deben ser versionados.
!Dockerfile  # Mantén este archivo
!docker-compose.yml # Y este también
docker-compose.override.yml
.env  # Archivo de variables de entorno, que a menudo contiene credenciales sensibles
*.log
*.sqlite  # Bases de datos de SQLite (si se usan)
volumes/
database/

---
# Archivos de agentes
# ---
# Los agentes a menudo generan logs o datos de estado
# que no deben ser versionados.
*.log
*.tmp
*.state
# Si tu agente guarda datos en una carpeta específica, agrégala aquí.
# Por ejemplo:
# logs/
# data/

---
# Otros
# ---
.env.production
.env.local
.env.development
.idea/  # Directorio de configuración de JetBrains (PyCharm, IntelliJ, etc.)
npm-debug.log
yarn-debug.log
.nyc_output/
.coverage